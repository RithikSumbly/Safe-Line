# SafeLine — global environment (Frontend + Backend)
# Copy to .env and fill in values. Never commit .env.

# ── Frontend (VITE_* is exposed to the browser — no secrets here) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_API_BASE_URL=http://localhost:8000
VITE_WHATSAPP_NUMBER=15551709431
VITE_WHATSAPP_NUMBER_DISPLAY=+1 (555) 170-9431

# ── Backend — LLM ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Backend — Supabase (service role is server-only) ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Backend — server ──
CORS_ORIGINS=http://localhost:5173
PORT=8000

# Agent API hardening (guest mode stays on by default)
API_REQUIRE_AUTH=false
API_CSRF_ENABLED=true
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_GUEST_PER_HOUR=20
API_RATE_LIMIT_AUTH_PER_HOUR=120

# ── Backend — external APIs (optional, improves evidence quality) ──
GOOGLE_SAFE_BROWSING_KEY=YOUR_GOOGLE_SAFE_BROWSING_KEY
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY
# PHISHTANK_API_KEY=   # discontinued — not used
GOOGLE_FACT_CHECK_KEY=YOUR_GOOGLE_FACT_CHECK_KEY
NEWSAPI_KEY=YOUR_NEWSAPI_KEY
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# ── Backend — Meta WhatsApp Cloud API ──
META_WHATSAPP_TOKEN=EAAB...YOUR_META_TOKEN
META_PHONE_NUMBER_ID=123456789012345
META_VERIFY_TOKEN=safeline-verify-token
META_APP_SECRET=YOUR_META_APP_SECRET

# HF Spaces cannot TLS-connect to graph.facebook.com — relay outbound via Vercel.
WHATSAPP_SEND_RELAY_URL=https://safe-line-khaki.vercel.app/api/whatsapp/send
WHATSAPP_RELAY_SECRET=generate-a-long-random-string

# Set on Vercel too (server-only, not VITE_*): META_WHATSAPP_TOKEN, META_PHONE_NUMBER_ID, WHATSAPP_RELAY_SECRET

# ── Backend — optional rate limiting ──
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Optional: Hugging Face token (do NOT commit real tokens) ──
# HF_WRITE_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
