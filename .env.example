# SafeLine — global environment (Frontend + Backend)
# Copy to .env and fill in values. Never commit .env.

# ── Frontend (VITE_* is exposed to the browser — no secrets here) ──
VITE_SUPABASE_URL=https://fnkxabyvnqkykpnzhxrk.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:8000
VITE_WHATSAPP_NUMBER=919876543210

# ── Backend — LLM ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Backend — Supabase (service role is server-only) ──
SUPABASE_URL=https://fnkxabyvnqkykpnzhxrk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Backend — server ──
CORS_ORIGINS=http://localhost:5173
PORT=8000

# ── Backend — external APIs (optional, improves evidence quality) ──
GOOGLE_SAFE_BROWSING_KEY=
VIRUSTOTAL_API_KEY=
# PHISHTANK_API_KEY=   # discontinued — not used
GOOGLE_FACT_CHECK_KEY=
NEWSAPI_KEY=
TAVILY_API_KEY=

# ── Backend — Meta WhatsApp Cloud API ──
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=safeline-verify-token
META_APP_SECRET=

# ── Backend — optional rate limiting ──
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
